# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
dist/
build/
*.egg-info/
.eggs/

# uv
uv.lock.bak

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# Ruff
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb~

# Quarto
# Note: `docs/` is the publish target for GitHub Pages and IS committed.
# Source .qmd files live in `website/`; only its build caches are ignored.
website/.quarto/
website/_freeze/
website/.jupyter_cache/
website/_site/

# Azure / secrets
.env
.env.local
*.pem
*.key

# Data (never commit raw data or model weights)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/splits/*
!data/splits/.gitkeep
models/

# MLflow
mlruns/
mlartifacts/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# Docker
docker/secrets/

# Bicep compiled output
infra/**/*.json
!infra/**/*.parameters.json

# Reports — keep summary metrics, drop large per-frame logs
reports/*.jsonl

# Ad-hoc model weight downloads at repo root (e.g. yolov8n.pt pretrained)
/*.pt

